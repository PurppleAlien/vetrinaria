# =============================================================================
# Vetrinaria - Variables de Entorno para Producción (Vercel + Supabase + Upstash)
# =============================================================================
# Copia este archivo como .env.production y completa los valores.
# Luego súbelos como Environment Variables en Vercel.
#
# Para obtener los valores de Supabase:
#   1. Crea un proyecto en https://supabase.com
#   2. Ve a Project Settings → Database → Connection string (modo pool: puerto 6543)
#   3. Ve a Project Settings → API → project_url y service_role_key
#
# Para Upstash:
#   1. Crea una base de datos Redis en https://console.upstash.com
#   2. Copia UPSTASH_REDIS_REST_URL y UPSTASH_REDIS_REST_TOKEN
# =============================================================================

# --- Base de Datos (Supabase PostgreSQL) ---
# Usar el connection string con pooler de Supabase (puerto 6543)
DATABASE_URL=postgresql://postgres:password@db.xrefcvsnfdoxgbbxzlcr.supabase.co:6543/postgres?sslmode=require

# --- Supabase Storage ---
NEXT_PUBLIC_SUPABASE_URL=https://xrefcvsnfdoxgbbxzlcr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Autenticación (NextAuth v5) ---
AUTH_SECRET=generar-con: openssl rand -base64 32
AUTH_URL=https://vetrinaria.vercel.app

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Resend ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=https://vetrinaria.vercel.app
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
