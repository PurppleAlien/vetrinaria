# =============================================================================
# Vetrinaria - Variables de Entorno para Desarrollo Local
# =============================================================================

# --- Base de Datos ---
# Local: Docker PostgreSQL
DATABASE_URL=postgresql://vet:secret@localhost:5433/vetrinaria

# --- Autenticación ---
AUTH_SECRET=dev-secret-key-do-not-use-in-production
AUTH_URL=http://localhost:3000

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase Storage (para desarrollo, opcional) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (Upstash, opcional en dev) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Stripe (opcional en dev) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Twilio (opcional en dev) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- Resend (opcional en dev) ---
# RESEND_API_KEY=
